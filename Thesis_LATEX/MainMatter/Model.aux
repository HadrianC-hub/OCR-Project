\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces Comparación del CER \textit  {in-sample} (azul) y el CER LOFO (naranja) para cada una de las nueve fuentes del \textit  {corpus} original. La línea discontinua marca el CER \textit  {in-sample} global (0,0106) y la línea punteada marca el CER LOFO promedio (0,0192). La fuente con menor degradación es CrimsonPro y la fuente con mayor degradación es CutiveMono.}}{64}{figure.caption.21}\protected@file@percent }
\newlabel{fig:lofo-por-fuente}{{4.6}{64}{Comparación del CER \textit {in-sample} (azul) y el CER LOFO (naranja) para cada una de las nueve fuentes del \textit {corpus} original. La línea discontinua marca el CER \textit {in-sample} global (0,0106) y la línea punteada marca el CER LOFO promedio (0,0192). La fuente con menor degradación es CrimsonPro y la fuente con mayor degradación es CutiveMono}{figure.caption.21}{}}
